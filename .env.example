# FriendlyMinter — Environment Variables
# Copy this file to `.env.local` and fill in real values for local development.
# For Vercel deployments, set the same keys in the project settings.

# -----------------------------------------------------------------------------
# Solana network
# -----------------------------------------------------------------------------
# Available: 'devnet' | 'testnet' | 'mainnet-beta'
# Defaults to 'devnet' if unset. Demo deployment uses devnet — no real funds.
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# -----------------------------------------------------------------------------
# RPC endpoints
# -----------------------------------------------------------------------------
# Optional: override the default RPC. Leave blank to use the public devnet RPC.
# Examples:
#   SOLANA_RPC_URL=https://api.devnet.solana.com
#   SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_URL=https://api.devnet.solana.com

NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_ANKR_RPC_URL=

# -----------------------------------------------------------------------------
# Backend deployer wallet (server-only)
# -----------------------------------------------------------------------------
# This is the keypair that pays for Merkle tree creation and minting fees on
# devnet. Fund it with a few SOL via:
#   solana airdrop 2 <pubkey> --url devnet
#
# Export the secret key as a base58 string (NOT a JSON array). To convert a
# Solana CLI JSON keypair file:
#   node -e "console.log(require('bs58').encode(new Uint8Array(require('./keys/devnet-deployer.json'))))"
# Paste the resulting string below.
#
# IMPORTANT: never commit the real value. .env* files are gitignored.
DEPLOYER_SECRET_KEY=

# -----------------------------------------------------------------------------
# Backend behaviour
# -----------------------------------------------------------------------------
# When true, the API routes try to sign real transactions. When false, they
# return mock responses (UI shows a "demo mode" banner).
BACKEND_LIVE=true

# -----------------------------------------------------------------------------
# Demo data behaviour (UI only)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_USE_MOCK_API=false
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_MOCK_DELAY=800