# FriendlyMinter — Environment Variables
# Copy this file to `.env.local` and fill in real values for local development.
# For Vercel deployments, set the same keys in the project settings.

# -----------------------------------------------------------------------------
# Solana network
# -----------------------------------------------------------------------------
# Available: 'devnet' | 'testnet' | 'mainnet-beta'
# Defaults to 'devnet' if unset. Demo deployment uses devnet — no real funds.
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# -----------------------------------------------------------------------------
# RPC endpoints
# -----------------------------------------------------------------------------
# Optional: override the public/ankr RPC. Leave blank to use the built-in
# Ankr endpoint for the chosen network.
#
# Examples:
#   NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
#   NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_SOLANA_RPC_URL=

# Back-compat alias read by lib/solana.ts
NEXT_PUBLIC_ANKR_RPC_URL=

# -----------------------------------------------------------------------------
# Demo data behaviour
# -----------------------------------------------------------------------------
# When true, the UI uses mock data (no backend required).
NEXT_PUBLIC_USE_MOCK_API=true
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_MOCK_DELAY=1000
