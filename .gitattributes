* text=auto eol=lf

# Force CRLF for Windows-specific files
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Mark binaries
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.woff     binary
*.woff2    binary

# Lockfiles: keep LF, suppress diff noise in PR reviews
package-lock.json  -diff linguist-generated=true
