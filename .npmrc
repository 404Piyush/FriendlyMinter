# Lock npm behaviour across dev / CI / Vercel.
# This file is read by npm itself; commit it alongside package-lock.json.

# Pin to the exact version listed in package.json (no ^ or ~).
save-exact=true

# Fail loudly if the project requires a different Node version than this one.
engine-strict=true

# Fund always false (we don't need the post-install nag).
fund=false

# Audit always false at install (we run `npm audit` separately in CI / locally).
audit=false

# Prefer offline cache when available; useful in CI.
prefer-offline=true